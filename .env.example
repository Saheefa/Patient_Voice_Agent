# --- Database ---
# Leave unset for local dev to use SQLite (./patients.db).
# In production (Vercel), set to a hosted Postgres connection string
# (Vercel Postgres / Neon / Supabase) since Vercel's filesystem is ephemeral.
DATABASE_URL=

# --- Vapi (Voice AI platform) ---
# From your Vapi dashboard: Account Settings > API Keys
VAPI_API_KEY=
# Created after you configure the assistant in the Vapi dashboard
VAPI_ASSISTANT_ID=
# Purchased/imported phone number's ID in Vapi
VAPI_PHONE_NUMBER_ID=

# --- LLM ---
# Only needed if you connect your own OpenAI key in Vapi rather than using
# Vapi's built-in provider credits
OPENAI_API_KEY=
